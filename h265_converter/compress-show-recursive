#!/usr/bin/env bash
# compress-show-recursive — recursively re-encode MKV video to H.265, skips already H.265
# Usage: compress-show-recursive [folder]   (defaults to current directory)

set -euo pipefail

LOCK="/tmp/compress-show-recursive.lock"
[ -f "$LOCK" ] && { echo "Already running (lock: $LOCK). Exiting."; exit 1; }
touch "$LOCK"
trap "rm -f '$LOCK'" EXIT

TARGET_DIR="$(realpath "${1:-.}")"
LOG_DIR="$HOME/logs"
LOG="$LOG_DIR/compress_show_recursive_$(date +%Y%m%d_%H%M%S).log"


mkdir -p "$LOG_DIR"

# Clean up logs older than 30 days
find "$LOG_DIR" -name "compress_show_recursive_*.log" -mtime +30 -delete

log() { echo "$1" | tee -a "$LOG"; }

log "Starting  — $(date)"
log "Folder    — $TARGET_DIR"
log ""

while IFS= read -r -d '' input; do
    base="$(basename "$input")"

    codec=$(ffprobe -v error \
        -select_streams v:0 \
        -show_entries stream=codec_name \
        -of csv=p=0 "$input" 2>/dev/null)

    if [[ "$codec" == "hevc" ]]; then
        log "Skipping (already H.265): $base"
        continue
    fi

    tmp="${input%.mkv}._tmp.mkv"
    log "Encoding: $base"

    if ffmpeg -y -hide_banner -loglevel error \
        -i "$input" \
        -map 0 \
        -c:v libx265 -crf 24 -preset slow \
        -c:a copy \
        -c:s copy \
        "$tmp"; then

        orig_size=$(stat -c%s "$input")
        new_size=$(stat -c%s "$tmp")

        if [[ -s "$tmp" && $new_size -lt $orig_size ]]; then
            rm "$input"
            mv "$tmp" "$input"
            log "  Done: $base ($(( orig_size / 1024 / 1024 ))MB → $(( new_size / 1024 / 1024 ))MB)"
        else
            rm -f "$tmp"
            log "  SKIPPED — output not smaller, kept original: $base"
        fi
    else
        rm -f "$tmp"
        log "  FAILED — kept original: $base"
    fi

    log ""

done < <(find "$TARGET_DIR" -type f -iname "*.mkv" -print0 | sort -z)

log "Finished — $(date)"

